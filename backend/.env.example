# Admin credentials (required for admin API access)
HISMAP_ADMIN_USER=admin
HISMAP_ADMIN_PASSWORD=change-me

# JWT secret (required — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
HISMAP_SECRET_KEY=change-me

# Database
HISMAP_DATABASE_URL=postgresql+asyncpg://hismap:hismap@localhost:5432/hismap
